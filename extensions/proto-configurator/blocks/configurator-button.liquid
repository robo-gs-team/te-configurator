{% comment %}
  Proto Configurator — "Configure Racquet" button (v2)
  Add via Theme Editor > Product pages > Add block (or reuse an existing placement).

  A self-contained, additive button that opens the v2 configurator modal. It NEVER touches the
  theme's buy box, the native Add to Cart, or the merchant's existing (legacy) configurator —
  the [data-proto-v2-standalone] marker tells the app JS to skip all DOM surgery for the page
  (see entry.tsx#isStandaloneV2Mode). It stays hidden until the app confirms this racquet is
  assigned to a v2 configurator (via the html.proto-configurator-linked / -unlinked / -pending
  classes the app toggles).

  By default the button inherits the theme's own primary-button styling (the same look as the
  native Add to Cart) via the theme's `button accent` classes, so it matches the store — but its
  own layout (width/display/gap) is forced with !important, since some theme CSS targets those
  same classes with a narrower layout meant for a different original context (this block isn't
  wrapped in the theme's .add_to_cart_holder for that reason — that wrapper shrank the button
  when placed directly under Quantity/Add to cart). A gear icon sits before the label and rotates
  slightly on hover. Colours can be overridden per-block.
{% endcomment %}

{% assign button_label = block.settings.button_label | default: 'Configure Racquet' %}

{% if block.settings.show_button %}
  <div
    class="proto-configurator-button-wrapper proto-v2-standalone-wrapper"
    data-proto-v2-standalone
    {{ block.shopify_attributes }}
  >
    <button
      type="button"
      class="proto-v2-configure-trigger button accent single-add-to-cart-button"
      data-proto-configurator-trigger
      data-proto-v2-standalone
      data-product-id="{{ product.id }}"
      {% if block.settings.button_bg != blank %}
        style="background-color: {{ block.settings.button_bg }}; color: {{ block.settings.button_text | default: '#ffffff' }}; border-color: {{ block.settings.button_bg }};"
      {% endif %}
    >
      {% if block.settings.show_gear %}
        <svg
          class="proto-v2-gear"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          focusable="false"
        >
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
      {% endif %}
      <span class="single-add-to-cart-button--text proto-v2-label">{{ button_label }}</span>
    </button>

    {% if block.settings.subtext != blank %}
      <p class="proto-v2-standalone-subtext">{{ block.settings.subtext }}</p>
    {% endif %}
  </div>

  <style>
    .proto-v2-standalone-wrapper {
      margin: 12px 0;
      width: 100%;
      max-width: 100%;
    }

    /* Inherit the theme's button look (color, font, radius, border) via the theme's own button
       classes; force layout ourselves with !important, since this block can be placed inside
       containers whose own CSS targets those same theme classes with higher specificity than a
       plain class rule here (that's what shrank the button when placed under Quantity/Add to
       cart — a theme rule sized for a different original layout was winning the cascade). */
    .proto-v2-configure-trigger {
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 8px !important;
      width: 100% !important;
      max-width: none !important;
      flex: 1 1 100% !important;
      white-space: nowrap;
      cursor: pointer;
    }

    .proto-v2-gear {
      flex: 0 0 auto;
      width: 18px;
      height: 18px;
      transition: transform 0.45s ease;
    }

    .proto-v2-configure-trigger:hover .proto-v2-gear,
    .proto-v2-configure-trigger:focus-visible .proto-v2-gear {
      transform: rotate(90deg);
    }

    .proto-v2-label {
      letter-spacing: 0.01em;
    }

    .proto-v2-standalone-subtext {
      margin: 6px 0 0;
      font-size: 12px;
      line-height: 1.4;
      text-align: center;
      opacity: 0.65;
    }

    /* Hidden until the app confirms this racquet is assigned to a v2 configurator, so the button
       never flashes before the linkage check resolves. Mirrors the app embed's linkage rules. */
    html.proto-configurator-pending .proto-v2-standalone-wrapper {
      visibility: hidden;
    }

    html.proto-configurator-unlinked .proto-v2-standalone-wrapper {
      display: none !important;
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Configurator Button",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show Configure Racquet button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Configure Racquet"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext under button",
      "default": "New: build your string setup in seconds",
      "info": "Small line shown under the button. Leave blank to hide it."
    },
    {
      "type": "checkbox",
      "id": "show_gear",
      "label": "Show gear icon",
      "default": true
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "paragraph",
      "content": "Leave the background blank to match your theme's primary button style automatically."
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background (optional override)"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text colour (optional override)",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
