{% comment %}
  Proto Switcher Configurator — App Embed
  Enable via Theme Editor > App embeds > Proto Configurator
  Loads the configurator modal script globally on the storefront.
{% endcomment %}

{% if block.settings.enabled %}
  <script>
    document.documentElement.classList.add('proto-configurator-pending');
  </script>
  <script>
    window.ProtoConfiguratorSettings = {
      appProxyUrl: {{ block.settings.app_proxy_url | default: '/apps/proto-configurator' | json }},
      productId: {{ product.id | default: '' | json }},
      shopDomain: {{ shop.permanent_domain | default: shop.domain | json }}
    };
  </script>
  <script src="{{ 'proto-configurator.js' | asset_url }}" defer></script>
  {{ 'proto-configurator.css' | asset_url | stylesheet_tag }}

  <style>
    #proto-configurator-root {
      position: relative;
      z-index: 99999;
    }

    /* Fallback when JS marks body — hide Buy now only (quantity stays visible) */
    body.proto-stringing-strung .shopify-payment-button,
    body.proto-stringing-strung shopify-accelerated-checkout,
    body.proto-stringing-strung .shopify-buy-it-now-button {
      display: none !important;
    }

    .proto-configurator-actions--inline {
      margin-top: 0 !important;
      flex: 1 1 auto;
      min-width: 0;
      width: 100%;
    }

    .proto-configurator-actions--inline .proto-configurator-trigger {
      width: 100%;
    }

    .proto-configurator-button-wrapper {
      margin: 12px 0;
      width: 100%;
      max-width: 100%;
      position: relative;
      z-index: 20;
      isolation: isolate;
    }

    .product__info .proto-configurator-button-wrapper,
    #ProductInfo .proto-configurator-button-wrapper,
    .product-info .proto-configurator-button-wrapper {
      margin-top: 8px;
      margin-bottom: 12px;
    }

    .proto-configurator-field {
      margin-bottom: 12px;
    }

    .proto-configurator-label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: 600;
      color: inherit;
    }

    .proto-configurator-select-wrap {
      position: relative;
    }

    .proto-configurator-select-wrap::after {
      content: '';
      position: absolute;
      top: 50%;
      right: 16px;
      width: 0;
      height: 0;
      pointer-events: none;
      border-left: 5px solid transparent;
      border-right: 5px solid transparent;
      border-top: 6px solid currentColor;
      transform: translateY(-25%);
      opacity: 0.65;
    }

    .proto-configurator-select {
      appearance: none;
      -webkit-appearance: none;
      width: 100%;
      min-height: 48px;
      padding: 12px 44px 12px 16px;
      border: 1px solid rgba(0, 0, 0, 0.15);
      border-radius: 4px;
      background: #fff;
      color: inherit;
      font: inherit;
      line-height: 1.4;
      cursor: pointer;
    }

    .proto-configurator-select:focus {
      outline: 2px solid rgba(59, 130, 246, 0.45);
      outline-offset: 1px;
    }

    .proto-configurator-actions[hidden] {
      display: none !important;
    }

    .proto-configurator-actions {
      position: relative;
      z-index: 21;
    }

    .proto-configurator-trigger {
      position: relative;
      z-index: 22;
      pointer-events: auto !important;
      cursor: pointer !important;
    }

    html.proto-configurator-pending .proto-configurator-button-wrapper {
      visibility: hidden;
    }

    html.proto-configurator-unlinked .proto-configurator-button-wrapper {
      display: none !important;
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Proto Configurator",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable configurator",
      "default": true
    },
    {
      "type": "text",
      "id": "app_proxy_url",
      "label": "App proxy URL",
      "default": "/apps/proto-configurator",
      "info": "Default app proxy path. Change only if customized in Partners dashboard."
    }
  ]
}
{% endschema %}
