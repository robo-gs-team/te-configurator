{% comment %}
  Proto Switcher Configurator — App Embed
  Enable via Theme Editor > App embeds > Proto Configurator
  Loads the configurator modal script globally on the storefront.
{% endcomment %}

{% if block.settings.enabled %}
  {% comment %}
    Release channel (Stable/Beta). Per-theme setting: the live/published theme should stay on
    "stable" (the frozen, known-good bundle), while a draft/duplicate theme can be set to "beta" to
    run the latest code without touching the live theme. Both bundles ship in the extension; this
    only picks which one THIS theme loads. See package.json build:storefront:beta / promote:stable.
  {% endcomment %}
  {% assign proto_channel = block.settings.channel | default: 'stable' %}
  {% if proto_channel == 'beta' %}
    {% assign proto_js = 'proto-configurator.beta.js' %}
    {% assign proto_css = 'proto-configurator.beta.css' %}
    {% assign proto_modal = 'proto-configurator-modal.beta.js' %}
  {% else %}
    {% assign proto_js = 'proto-configurator.js' %}
    {% assign proto_css = 'proto-configurator.css' %}
    {% assign proto_modal = 'proto-configurator-modal.js' %}
  {% endif %}

  <script>
    document.documentElement.classList.add('proto-configurator-pending');
  </script>
  <script>
    window.ProtoConfiguratorSettings = {
      appProxyUrl: {{ block.settings.app_proxy_url | default: '/apps/proto-configurator' | json }},
      productId: {{ product.id | default: '' | json }},
      shopDomain: {{ shop.permanent_domain | default: shop.domain | json }},
      channel: {{ proto_channel | json }},
      modalUrl: {{ proto_modal | asset_url | json }}
    };
    /* Perf: start the linkage fetch NOW, during HTML parse, instead of after the deferred bundle
       downloads + executes — the App Proxy round-trip overlaps page load. The bundle consumes
       this promise for its first attempt (entry.tsx#fetchConfiguratorAttempt) and falls back to
       its own retrying fetch if it's absent or failed. */
    (function () {
      try {
        var s = window.ProtoConfiguratorSettings;
        if (s && s.productId) {
          var q = s.shopDomain ? '?shop=' + encodeURIComponent(s.shopDomain) : '';
          window.ProtoConfiguratorEarlyFetch = window.fetch(
            s.appProxyUrl + '/product/' + s.productId + q,
            { credentials: 'same-origin', headers: { Accept: 'application/json' } }
          );
          /* Swallow here so an offline/failed early fetch never surfaces as an unhandled
             rejection; the bundle re-fetches with retries on its own. */
          window.ProtoConfiguratorEarlyFetch.catch(function () {});
        }
      } catch (e) { /* no-op — bundle fetches normally */ }
    })();
  </script>
  <script src="{{ proto_js | asset_url }}" defer></script>
  {{ proto_css | asset_url | stylesheet_tag }}

  <style>
    #proto-configurator-root {
      position: relative;
      z-index: 99999;
    }

    /* Fallback when JS marks body — hide Buy now only (quantity stays visible) */
    body.proto-stringing-strung .shopify-payment-button,
    body.proto-stringing-strung shopify-accelerated-checkout,
    body.proto-stringing-strung .shopify-buy-it-now-button {
      display: none !important;
    }

    .proto-configurator-actions--inline {
      margin-top: 0 !important;
      flex: 1 1 auto;
      min-width: 0;
      width: 100%;
    }

    .proto-configurator-actions--inline .proto-configurator-trigger {
      width: 100%;
    }

    .proto-configurator-button-wrapper {
      margin: 12px 0;
      width: 100%;
      max-width: 100%;
      position: relative;
      z-index: 20;
      isolation: isolate;
    }

    .product__info .proto-configurator-button-wrapper,
    #ProductInfo .proto-configurator-button-wrapper,
    .product-info .proto-configurator-button-wrapper {
      margin-top: 8px;
      margin-bottom: 12px;
    }

    .proto-configurator-field {
      margin-bottom: 12px;
    }

    .proto-configurator-label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      font-weight: 600;
      color: inherit;
    }

    .proto-configurator-select-wrap {
      position: relative;
    }

    .proto-configurator-select-wrap::after {
      content: '';
      position: absolute;
      top: 50%;
      right: 16px;
      width: 0;
      height: 0;
      pointer-events: none;
      border-left: 5px solid transparent;
      border-right: 5px solid transparent;
      border-top: 6px solid currentColor;
      transform: translateY(-25%);
      opacity: 0.65;
    }

    .proto-configurator-select {
      appearance: none;
      -webkit-appearance: none;
      width: 100%;
      min-height: 48px;
      padding: 12px 44px 12px 16px;
      border: 1px solid rgba(0, 0, 0, 0.15);
      border-radius: 4px;
      background: #fff;
      color: inherit;
      font: inherit;
      line-height: 1.4;
      cursor: pointer;
    }

    .proto-configurator-select:focus {
      outline: 2px solid rgba(59, 130, 246, 0.45);
      outline-offset: 1px;
    }

    .proto-configurator-actions[hidden] {
      display: none !important;
    }

    .proto-configurator-actions {
      position: relative;
      z-index: 21;
    }

    .proto-configurator-trigger {
      position: relative;
      z-index: 22;
      pointer-events: auto !important;
      cursor: pointer !important;
    }

    html.proto-configurator-pending .proto-configurator-button-wrapper {
      visibility: hidden;
    }

    html.proto-configurator-unlinked .proto-configurator-button-wrapper {
      display: none !important;
    }

    html[data-proto-stringing-state="unstrung"] [data-proto-configurator-actions],
    html[data-proto-stringing-state="unstrung"] .proto-configurator-trigger {
      display: none !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Proto Configurator",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable configurator",
      "default": true
    },
    {
      "type": "select",
      "id": "channel",
      "label": "Version",
      "default": "stable",
      "options": [
        { "value": "stable", "label": "Stable (recommended for your live theme)" },
        { "value": "beta", "label": "Beta (latest — for a test/draft theme only)" }
      ],
      "info": "Stable = the frozen, tested bundle. Beta = the latest build, for trying new changes on a draft theme without affecting your live theme. Set Beta ONLY on a duplicate/test theme."
    },
    {
      "type": "text",
      "id": "app_proxy_url",
      "label": "App proxy URL",
      "default": "/apps/proto-configurator",
      "info": "Default app proxy path. Change only if customized in Partners dashboard."
    }
  ]
}
{% endschema %}
