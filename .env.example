# Shopify App Credentials (from Partners Dashboard > Apps > Your App)
SHOPIFY_API_KEY=your_client_id
SHOPIFY_API_SECRET=your_client_secret
# read_orders powers best-seller string sorting (units sold, last 60d). Adding it triggers a
# one-time merchant re-consent on next app load. Must match the scopes in shopify.app.toml exactly
# (this file previously drifted from the toml after read_collections was removed there — always
# verify against shopify.app.toml or the Dev Dashboard's Versions page, not this file, before
# setting the real SCOPES env var).
SCOPES=read_products,write_products,read_themes,write_themes,read_orders

# App URL (set automatically by `shopify app dev`, or your Vercel production URL)
SHOPIFY_APP_URL=https://your-app.vercel.app

# Private single-store: fixed shop domain (optional, simplifies login)
SHOP=your-store.myshopify.com

# Shopify CLI deploy token (Dev Dashboard → App → Settings → App Automation Token)
# Used by CI and optional local deploys: npm run deploy
# SHOPIFY_APP_AUTOMATION_TOKEN=your_app_automation_token

# PostgreSQL (required for Vercel; use Neon, Vercel Postgres, or Supabase)

# --- Supabase (recommended for this project) ---
# In Supabase: Connect → copy BOTH strings below (replace [YOUR-PASSWORD]).
#
# DATABASE_URL = Transaction pooler (port 6543) — app runtime on Vercel
# DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL = Session pooler (port 5432 on pooler host) — Prisma migrations on Vercel
# Do NOT use db.[project-ref].supabase.co here — Vercel cannot reach it (P1001 error).
# DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- Generic PostgreSQL ---
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Vercel Postgres ---
# DATABASE_URL = POSTGRES_PRISMA_URL (pooled)
# DIRECT_URL   = POSTGRES_URL_NON_POOLING (direct)
